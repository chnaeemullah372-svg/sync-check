NODE_ENV=production

# Runtime surface for this process:
# - public: serves punjab-case-management.live and www, blocks /admin and /card/admin.
# - admin: serves admin.punjab-case-management.live, blocks /user.
APP_SURFACE=public
PUBLIC_HOSTS=punjab-case-management.live,www.punjab-case-management.live
ADMIN_HOSTS=admin.punjab-case-management.live

# Supabase public client config. VITE_* values are baked into the browser build.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_PUBLIC_HOSTS=punjab-case-management.live,www.punjab-case-management.live
VITE_ADMIN_HOSTS=admin.punjab-case-management.live

# Server-only secrets. Never prefix these with VITE_ and never commit real values.
SUPABASE_SERVICE_ROLE_KEY=replace-on-server-only
LOVABLE_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
